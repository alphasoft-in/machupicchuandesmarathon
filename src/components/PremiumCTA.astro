---
import { useTranslations, useTranslatedPath } from '../utils/i18n.js';

const { lang } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const WHATSAPP_NUMBER = "51993187203";
const defaultMessage = lang === 'es' 
  ? "Hola, me gustaría planear mi próximo viaje con Machu Picchu Andes Marathon."
  : "Hello, I would like to plan my next trip with Machu Picchu Andes Marathon.";
const whatsappUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(defaultMessage)}`;
---

<section class="premium-cta">
  <div class="cta-overlay"></div>
  <div class="container cta-container">
    <div class="cta-content animate-fade-in">
      <span class="cta-tagline">{lang === 'es' ? 'EXPERIENCIAS ÚNICAS' : 'UNIQUE EXPERIENCES'}</span>
      <h2 class="cta-title">
        {lang === 'es' ? '¿Listo para tu próxima' : 'Ready for Your Next'} 
        <span class="text-secondary">{lang === 'es' ? 'Aventura?' : 'Adventure?'}</span>
      </h2>
      
      <p class="cta-description">
        {lang === 'es' 
          ? 'Únete a nosotros en un viaje inolvidable por el corazón del Imperio Inca. Diseñamos expediciones que transforman el alma.' 
          : 'Join us for an unforgettable journey through the heart of the Inca Empire. We craft expeditions that transform the soul.'}
      </p>

      <div class="cta-actions">
        <a 
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary"
        >
          {lang === 'es' ? 'Planea tu Viaje' : 'Plan Your Trip'}
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width: 20px; height: 20px; margin-left: 8px;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        
        <a 
          href={translatePath('/inca-trail')}
          class="btn btn-outline"
        >
          {lang === 'es' ? 'Ver Expediciones' : 'View Expeditions'}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .premium-cta {
    position: relative;
    padding: 120px 0;
    background-image: url('/images/cta-bg.webp');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    overflow: hidden;
    color: white;
  }

  .cta-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(14, 59, 46, 0.95) 0%, rgba(14, 59, 46, 0.6) 100%);
    z-index: 1;
  }

  .cta-container {
    position: relative;
    z-index: 2;
  }

  .cta-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-tagline {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 4px;
    color: var(--secondary);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }

  .cta-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    font-family: var(--font-serif);
  }

  .cta-description {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    margin-bottom: 3rem;
    opacity: 0.9;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .cta-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .text-secondary {
    color: var(--secondary);
  }

  @media (max-width: 768px) {
    .premium-cta {
      padding: 80px 0;
      background-attachment: scroll; /* Better for mobile performance */
    }
    
    .cta-actions {
      flex-direction: column;
      align-items: center;
    }
    
    .cta-actions .btn {
      width: 100%;
      max-width: 300px;
    }
  }
</style>
