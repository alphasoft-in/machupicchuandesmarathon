---
import Layout from '../../layouts/Layout.astro';
import { useTranslations, useTranslatedPath } from '../../utils/i18n';
import PageHeader from '../../components/PageHeader';
import BookingCTA from '../../components/BookingCTA';
import { Sun, Zap, Users, GraduationCap, Heart, Leaf, Rocket } from 'lucide-react';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}

const { lang: rawLang } = Astro.params;
const lang = rawLang as 'en' | 'es';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const content = {
  en: {
    title: "AYNI Project",
    subtitle: "Solar Energy for Andean Communities of Peru (2025–2027)",
    description: "The AYNI Project is a social initiative that seeks to bring clean, free, and sustainable electrical energy to low-income Andean communities in Peru, through the installation of home and community solar systems. Inspired by the Andean principle of reciprocity, AYNI connects donors, allies, and travelers with communities to generate long-term sustainable development.",
    phase: "Currently in the support-seeking phase, the project aims to benefit 500 families in 5 pilot communities, providing them with access to electricity for decades.",
    whyTitle: "Why is it necessary?",
    whyText: "In the Peruvian highlands, thousands of families still live without access to reliable electricity. This limits education, affects health, reduces economic opportunities, and generates negative environmental impacts due to the use of candles, kerosene, and firewood.",
    whyText2: "Thanks to the high solar radiation in the Andes, photovoltaic energy is an efficient, sustainable, and low-maintenance solution to close this gap.",
    objectivesTitle: "Main Objectives",
    objectives: [
      { icon: Sun, text: "Install solar systems in homes and community spaces." },
      { icon: Zap, text: "Electrify schools and health centers." },
      { icon: Users, text: "Train local technicians to ensure sustainability." },
      { icon: Leaf, text: "Reduce the use of polluting fuels." },
      { icon: Rocket, text: "Create a replicable model for other regions of the country." }
    ],
    executionTitle: "Project Execution",
    executionText: "The project will be developed in phases between 2025 and 2027, including design, pilot installation, expansion, evaluation, and scaling to new communities.",
    impactTitle: "Expected Impact",
    impacts: [
      { icon: Zap, title: "Energy Access", text: "Electricity for hundreds of families" },
      { icon: GraduationCap, title: "Education", text: "Improvement in education (more study hours)" },
      { icon: Heart, title: "Health", text: "More efficient medical care" },
      { icon: Leaf, title: "Environment", text: "Reduction of polluting emissions" },
      { icon: Users, title: "Community", text: "Boosting the local economy and community strengthening" }
    ],
    ctaTitle: "Join the AYNI Project",
    ctaText: "This project also invites travelers roaming the Andes to be part of the change. Through their contribution, they can directly help improve the quality of life of local communities and leave a positive impact during their experience in Peru.",
    footerText: "AYNI is more than energy: it is development, human connection, and a future for the Andes."
  },
  es: {
    title: "Proyecto AYNI",
    subtitle: "Energía Solar para Comunidades Andinas del Perú (2025–2027)",
    description: "El Proyecto AYNI es una iniciativa social que busca llevar energía eléctrica limpia, gratuita y sostenible a comunidades andinas de escasos recursos en el Perú, mediante la instalación de sistemas solares domiciliarios y comunitarios. Inspirado en el principio andino de reciprocidad, AYNI conecta a donantes, aliados y viajeros con comunidades para generar desarrollo sostenible a largo plazo.",
    phase: "Actualmente en fase de búsqueda de apoyo, el proyecto tiene como meta beneficiar a 500 familias en 5 comunidades piloto, brindándoles acceso a electricidad por décadas.",
    whyTitle: "¿Por qué es necesario?",
    whyText: "En la sierra peruana, miles de familias aún viven sin acceso a electricidad confiable. Esto limita la educación, afecta la salud, reduce oportunidades económicas y genera impactos ambientales negativos debido al uso de velas, kerosene y leña.",
    whyText2: "Gracias a la alta radiación solar en los Andes, la energía fotovoltaica es una solución eficiente, sostenible y de bajo mantenimiento para cerrar esta brecha.",
    objectivesTitle: "Objetivos principales",
    objectives: [
      { icon: Sun, text: "Instalar sistemas solares en viviendas y espacios comunitarios." },
      { icon: Zap, text: "Electrificar escuelas y centros de salud." },
      { icon: Users, text: "Capacitar técnicos locales para asegurar sostenibilidad." },
      { icon: Leaf, text: "Reducir el uso de combustibles contaminantes." },
      { icon: Rocket, text: "Crear un modelo replicable para otras regiones del país." }
    ],
    executionTitle: "Ejecución del proyecto",
    executionText: "El proyecto se desarrollará por fases entre 2025 y 2027, incluyendo diseño, instalación piloto, expansión, evaluación y escalamiento a nuevas comunidades.",
    impactTitle: "Impacto esperado",
    impacts: [
      { icon: Zap, title: "Acceso Energía", text: "Acceso a electricidad para cientos de familias" },
      { icon: GraduationCap, title: "Educación", text: "Mejora en educación (más horas de estudio)" },
      { icon: Heart, title: "Salud", text: "Atención médica más eficiente" },
      { icon: Leaf, title: "Ambiente", text: "Reducción de emisiones contaminantes" },
      { icon: Users, title: "Comunidad", text: "Impulso a la economía local y fortalecimiento comunitario" }
    ],
    ctaTitle: "Súmate al Proyecto AYNI",
    ctaText: "Este proyecto también invita a viajeros que recorren los Andes a ser parte del cambio. A través de su aporte, pueden contribuir directamente a mejorar la calidad de vida de comunidades locales y dejar un impacto positivo durante su experiencia en el Perú.",
    footerText: "AYNI es más que energía: es desarrollo, conexión humana y futuro para los Andes."
  }
};

const tAyni = content[lang];
---

<Layout title={`${tAyni.title} | Peru Andes Trekking`} lang={lang}>
  <PageHeader 
    client:load
    lang={lang}
    title={tAyni.title}
    subtitle={tAyni.subtitle}
    bgImage="/images/bg-comunidades-andinas.avif"
  />

  <section class="py-16 md:py-24 bg-gradient-to-b from-white to-gray-50 relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-secondary/5 rounded-full blur-3xl"></div>
      <div class="absolute top-1/3 -left-24 w-72 h-72 bg-primary/5 rounded-full blur-3xl"></div>
    </div>

    <div class="container max-w-5xl mx-auto px-4 relative z-10">
      
      <!-- Intro Section -->
      <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16 animate-fade-in">
        <p class="text-base md:text-lg leading-relaxed text-gray-700 font-light">
          {tAyni.description}
        </p>
      </div>

      <!-- Phase Card (Glassmorphism) -->
      <div class="relative bg-white/80 backdrop-blur-md p-8 md:p-10 rounded-3xl mb-24 border border-secondary/20 shadow-xl shadow-secondary/5 hover:shadow-2xl transition-shadow duration-500 overflow-hidden group">
        <div class="absolute top-0 left-0 w-2 h-full bg-secondary"></div>
        <div class="absolute -right-10 -bottom-10 opacity-5 group-hover:scale-110 transition-transform duration-700">
          <Heart size={150} />
        </div>
        <p class="text-base m-0 font-medium italic text-gray-800 relative z-10">
          "{tAyni.phase}"
        </p>
      </div>

      <!-- Why is it necessary? -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12 mb-20 md:mb-24 items-center">
        <div>
          <h2 class="font-serif text-2xl lg:text-3xl mb-4 md:mb-6 text-gray-900 leading-tight">
            {tAyni.whyTitle}
            <span class="block w-12 md:w-16 h-1 bg-secondary mt-3 md:mt-4 rounded-full"></span>
          </h2>
          <p class="text-gray-600 text-base mb-4 md:mb-6 leading-relaxed">
            {tAyni.whyText}
          </p>
          <p class="text-gray-600 text-base leading-relaxed">
            {tAyni.whyText2}
          </p>
        </div>
        <div class="bg-primary/5 rounded-3xl p-8 border border-primary/10 relative">
          <div class="absolute -top-6 -right-6 bg-white p-4 rounded-2xl shadow-lg text-secondary animate-bounce">
            <Sun size={32} />
          </div>
          <img src="/images/bg-comunidades-andinas.avif" alt="Comunidades Andinas" class="rounded-2xl shadow-md w-full h-auto object-cover aspect-video" />
        </div>
      </div>

      <!-- Main Objectives -->
      <div class="mb-20 md:mb-24">
        <div class="text-center mb-10 md:mb-12">
          <h2 class="font-serif text-2xl lg:text-3xl text-gray-900 inline-block relative">
            {tAyni.objectivesTitle}
            <span class="absolute -bottom-3 left-1/2 -translate-x-1/2 w-10 md:w-12 h-1 bg-secondary rounded-full"></span>
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {tAyni.objectives.map((obj, index) => (
            <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-2 border border-gray-100 group relative overflow-hidden">
              <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-secondary/5 to-transparent rounded-bl-full -z-10 transition-transform group-hover:scale-150 duration-500"></div>
              <div class="bg-secondary/10 w-10 h-10 md:w-12 md:h-12 rounded-xl text-secondary flex items-center justify-center mb-4 md:mb-6 group-hover:bg-secondary group-hover:text-white transition-colors duration-300 shadow-sm">
                <obj.icon size={20} className="md:w-6 md:h-6" />
              </div>
              <p class="text-gray-800 font-medium text-base m-0">{obj.text}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Project Execution (Premium Dark Block) -->
      <div class="bg-gradient-to-br from-[#0e3b2e] to-[#1a5c48] p-10 md:p-16 rounded-3xl mb-24 relative overflow-hidden shadow-2xl group">
        <!-- Glow effect -->
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(252,97,17,0.15),transparent_50%)]"></div>
        
        <div class="relative z-10 md:w-2/3">
          <div class="inline-flex items-center gap-2 px-3 py-1 md:px-4 md:py-1.5 rounded-full bg-white/10 text-white/90 text-xs md:text-sm font-semibold tracking-wider uppercase mb-4 md:mb-6 border border-white/20 backdrop-blur-sm">
            <Rocket size={14} className="md:w-4 md:h-4" /> 2025 – 2027
          </div>
          <h2 class="font-serif text-xl sm:text-2xl lg:text-3xl mb-3 md:mb-5 text-white leading-tight">
            {tAyni.executionTitle}
          </h2>
          <p class="text-white/90 text-sm sm:text-base m-0 leading-relaxed font-light">
            {tAyni.executionText}
          </p>
        </div>
        <div class="absolute top-1/2 -translate-y-1/2 -right-10 md:right-10 opacity-10 text-white group-hover:scale-110 group-hover:opacity-20 transition-all duration-700 pointer-events-none">
           <Rocket size={240} strokeWidth={1} />
        </div>
      </div>

      <!-- Expected Impact -->
      <div class="mb-20 md:mb-24">
        <div class="text-center mb-12 md:mb-16">
          <h2 class="font-serif text-2xl lg:text-3xl text-gray-900 inline-block relative">
            {tAyni.impactTitle}
            <span class="absolute -bottom-3 left-1/2 -translate-x-1/2 w-10 md:w-12 h-1 bg-secondary rounded-full"></span>
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {tAyni.impacts.map((impact) => (
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 text-center hover:border-secondary/30 hover:shadow-lg transition-all duration-300 group">
              <div class="bg-primary/5 w-14 h-14 md:w-16 md:h-16 flex items-center justify-center rounded-full mx-auto mb-4 md:mb-6 text-primary relative group-hover:bg-primary group-hover:text-white transition-colors duration-500">
                <div class="absolute inset-0 border-2 border-primary/20 rounded-full scale-110 group-hover:scale-100 group-hover:border-transparent transition-all duration-500"></div>
                <impact.icon size={24} className="md:w-7 md:h-7" />
              </div>
              <h3 class="font-bold text-lg mb-2 md:mb-3 text-gray-900">{impact.title}</h3>
              <p class="text-sm text-gray-600 m-0">{impact.text}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA Section -->
      <div class="bg-gradient-to-r from-secondary to-orange-500 p-8 sm:p-10 md:p-16 rounded-3xl md:rounded-[2.5rem] shadow-xl shadow-secondary/20 text-center relative overflow-hidden group">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.avif')] opacity-10 mix-blend-overlay"></div>
        <div class="relative z-10">
          <h2 class="font-serif text-xl sm:text-2xl lg:text-3xl mb-4 md:mb-5 text-white drop-shadow-sm">
            {tAyni.ctaTitle}
          </h2>
          <p class="max-w-2xl mx-auto mb-8 md:mb-10 text-sm sm:text-base text-white/90 font-light leading-relaxed">
            {tAyni.ctaText}
          </p>
          <div class="inline-block bg-white/10 backdrop-blur-sm border border-white/30 p-4 md:p-6 rounded-2xl shadow-inner">
            <p class="font-bold text-white text-base sm:text-lg italic m-0 tracking-wide drop-shadow-md">
              "{tAyni.footerText}"
            </p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <BookingCTA client:visible lang={lang} />
</Layout>
