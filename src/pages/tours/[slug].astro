---
import Layout from '../../layouts/Layout.astro';
import { Star, Clock, MapPin, CheckCircle, ArrowRight, Calendar } from 'lucide-astro';
import { allTours } from '../../data/tours.js';

export function getStaticPaths() {
  return allTours.map(tour => ({
    params: { slug: tour.slug },
    props: { tour },
  }));
}

const { tour } = Astro.props;

const recommendations = allTours
  .filter(t => t.slug !== tour.slug)
  .slice(0, 4);
---

<Layout title={`${tour.title} | Machu Picchu Andes Marathon`}>
  <!-- Tour Hero -->
  <section class="tour-hero" style={`background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url(${tour.image})`}>
    <div class="container hero-content">
      <span class="tour-badge">{tour.tag}</span>
      <h1 class="serif">{tour.title}</h1>
      <div class="tour-meta-large">
        <span><Clock size="20" /> {tour.duration}</span>
        <span><Star size="20" fill="var(--secondary)" color="var(--secondary)" /> {tour.rating}</span>
        <span><MapPin size="20" /> Cusco, Peru</span>
      </div>
    </div>
  </section>

  <div class="container tour-layout">
    <main class="tour-details">
      <!-- Overview -->
      <section class="tour-section">
        <h2 class="serif">Tour Overview</h2>
        <p class="description-text">{tour.description}</p>
        
        <div class="highlights-grid">
          <div class="highlight-item">
            <CheckCircle size="24" color="var(--primary)" />
            <div>
              <strong>Professional Guides</strong>
              <p>Expert local historians and endurance experts.</p>
            </div>
          </div>
          <div class="highlight-item">
            <CheckCircle size="24" color="var(--primary)" />
            <div>
              <strong>Premium Equipment</strong>
              <p>Top-tier camping and safety gear included.</p>
            </div>
          </div>
          <div class="highlight-item">
            <CheckCircle size="24" color="var(--primary)" />
            <div>
              <strong>Gourmet Meals</strong>
              <p>Freshly prepared Andean fusion cuisine.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Itinerary -->
      <section class="tour-section">
        <h2 class="serif">Daily Itinerary</h2>
        <div class="itinerary-timeline">
          {tour.itinerary.map((item, index) => (
            <div class="timeline-day">
              <div class="day-number">Day {item.day}</div>
              <div class="day-content">
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    </main>

    <!-- Sidebar Booking -->
    <aside class="tour-sidebar">
      <div class="booking-card sticky">
        <div class="price-tag">
          <span>From</span>
          <h3>{tour.price}</h3>
        </div>
        
        <form class="sidebar-form">
          <div class="form-group">
            <label><Calendar size="16" /> Select Date</label>
            <input type="date" required />
          </div>
          <div class="form-group">
            <label>Travelers</label>
            <select>
              <option>1 Adult</option>
              <option>2 Adults</option>
              <option>3+ Adults</option>
            </select>
          </div>
          <button type="submit" class="btn btn-primary btn-full">
            Book Now <ArrowRight size="18" />
          </button>
        </form>

        <p class="sidebar-note">No payment required yet. Booking is safe and secure.</p>
      </div>
    </aside>
  </div>

  <!-- Recommended Tours -->
  <section class="section highlight-section pb-0">
    <div class="container">
      <div class="section-header">
        <div>
          <h2 class="serif">Related Experiences</h2>
          <p class="text-muted">Explore more wonders of the Andes.</p>
        </div>
      </div>

      <div class="compact-grid">
        {recommendations.map((rec, index) => (
          <a href={`/tours/${rec.slug}`} class={`compact-card animate-fade-in delay-${index}`}>
            <div class="compact-image">
              <img src={rec.image} alt={rec.title} />
            </div>
            <div class="compact-body">
              <span class="compact-tag">{rec.tag}</span>
              <h3 class="serif">{rec.title}</h3>
              <div class="compact-meta">
                <span>{rec.duration}</span>
                <span class="compact-price">{rec.price}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Compact Grid for Recommendations */
  .compact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .compact-card {
    background: white;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    transition: var(--transition);
    border: 1px solid #f0f0f0;
  }

  .compact-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
    border-color: var(--secondary);
  }

  .compact-image {
    height: 180px;
    overflow: hidden;
  }

  .compact-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition);
  }

  .compact-card:hover img {
    transform: scale(1.1);
  }

  .compact-body {
    padding: 1.25rem;
  }

  .compact-tag {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--secondary);
    letter-spacing: 1px;
    display: block;
    margin-bottom: 0.5rem;
  }

  .compact-body h3 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .compact-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
  }

  .compact-price {
    font-weight: 700;
    color: var(--primary);
  }

  @media (max-width: 1200px) {
    .compact-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .compact-grid { grid-template-columns: 1fr; }
  }

  .tour-hero {
    height: 70vh;
    min-height: 500px;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    color: white;
    padding-top: 100px;
  }

  .hero-content h1 {
    font-size: clamp(3rem, 8vw, 5rem);
    margin: 1.5rem 0;
  }

  .tour-badge {
    background: var(--secondary);
    padding: 0.5rem 1.5rem;
    border-radius: 30px;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 1px;
  }

  .tour-meta-large {
    display: flex;
    gap: 3rem;
    font-size: 1.25rem;
  }

  .tour-meta-large span {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* Tour Layout */
  .tour-layout {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 6rem;
    padding: 100px 0;
  }

  .tour-section {
    margin-bottom: 5rem;
  }

  .tour-section h2 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
  }

  .description-text {
    font-size: 1.2rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 3rem;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .highlight-item {
    display: flex;
    gap: 15px;
  }

  .highlight-item strong {
    display: block;
    margin-bottom: 5px;
  }

  .highlight-item p {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  /* Timeline */
  .itinerary-timeline {
    position: relative;
    padding-left: 100px;
  }

  .itinerary-timeline::before {
    content: '';
    position: absolute;
    left: 45px;
    top: 10px;
    bottom: 10px;
    width: 2px;
    background: #f0f0f0;
  }

  .timeline-day {
    position: relative;
    margin-bottom: 4rem;
  }

  .day-number {
    position: absolute;
    left: -100px;
    width: 80px;
    height: 34px;
    background: var(--primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 20px;
    font-weight: 700;
    font-size: 0.8rem;
    z-index: 10;
  }

  .day-content h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .day-content p {
    line-height: 1.7;
    color: var(--text-muted);
  }

  /* Sidebar */
  .booking-card {
    background: white;
    border-radius: 20px;
    padding: 2.5rem;
    box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    border: 1px solid #f0f0f0;
  }

  .sticky {
    position: sticky;
    top: 120px;
  }

  .price-tag {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .price-tag span {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .price-tag h3 {
    font-size: 2.5rem;
    color: var(--primary);
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .sidebar-form input, .sidebar-form select {
    width: 100%;
    padding: 1rem;
    border-radius: 10px;
    border: 1px solid #e0e0e0;
    font-family: inherit;
  }

  .btn-full {
    width: 100%;
    justify-content: center;
  }

  .sidebar-note {
    margin-top: 1.5rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-align: center;
  }

  @media (max-width: 1024px) {
    .tour-layout {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .tour-sidebar {
      order: -1;
    }
    .booking-card {
      position: static;
    }
    .highlights-grid {
      grid-template-columns: 1fr;
    }
    .itinerary-timeline {
      padding-left: 20px;
    }
    .itinerary-timeline::before {
      display: none;
    }
    .timeline-day {
      padding-top: 50px;
    }
    .day-number {
      left: 0;
      top: 0;
    }
  }
</style>
