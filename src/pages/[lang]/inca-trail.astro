---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, useTranslatedPath } from '../../utils/i18n';
import PageHeader from '../../components/PageHeader';
import TourGrid from '../../components/TourGrid';

import BookingForm from '../../components/BookingForm';
export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}

const { lang: rawLang } = Astro.params;
const lang = rawLang as 'en' | 'es';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const tours = await getCollection('tours');
const incaTours = tours
  .map(t => t.data)
  .filter(t => t.category === 'inca-trail');
---

<Layout title={`${t('nav.inca')} | Machu Picchu Andes Marathon`} lang={lang}>
  <PageHeader 
    client:load
    lang={lang}
    title={lang === 'en' ? 'Inca Trail' : 'Camino Inca'}
    titleAccent="Tours"
    subtitle={lang === 'en' ? "Explore the ancient pathways of the Incan Empire. Every step is a story, every view is a masterpiece." : "Explora los antiguos senderos del Imperio Inca. Cada paso es una historia, cada vista una obra maestra."}
    bgImage="/images/marathon.webp"
  />

  <section class="section">
    <div class="container">
      <TourGrid client:visible lang={lang} tours={incaTours} />
    </div>
  </section>

  <section class="section bg-muted">
    <div class="container max-w-2xl">
      <div class="text-center mb-10">
        <h2 class="serif text-4xl text-primary mb-4">{t('booking.title')}</h2>
        <p class="text-slate-500">{t('booking.subtitle')}</p>
      </div>
      <BookingForm client:visible lang={lang} />
    </div>
  </section>
</Layout>
