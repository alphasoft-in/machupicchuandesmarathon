---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, useTranslatedPath } from '../../utils/i18n';
import PageHeader from '../../components/PageHeader';
import TourGrid from '../../components/TourGrid';

import BookingCTA from '../../components/BookingCTA';
export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}

const { lang: rawLang } = Astro.params;
const lang = rawLang as 'en' | 'es';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const tours = await getCollection('tours');
const incaTours = tours
  .map(t => t.data)
  .filter(t => t.category === 'inca-trail');
---

<Layout title={`${t('nav.inca')} | Peru Andes Trekking`} lang={lang}>
  <PageHeader 
    client:load
    lang={lang}
    title={lang === 'en' ? 'Inca Trail' : 'Camino Inca'}
    titleAccent="Tours"
    subtitle={lang === 'en' ? "Explore the ancient pathways of the Incan Empire. Every step is a story, every view is a masterpiece." : "Explora los antiguos senderos del Imperio Inca. Cada paso es una historia, cada vista una obra maestra."}
    bgImage="/images/inca-trail/bg-inca-trail.avif"
  />

  <section class="py-10">
    <div class="container">
      <TourGrid client:visible lang={lang} tours={incaTours} />
    </div>
  </section>

  <BookingCTA client:visible lang={lang} />
</Layout>
