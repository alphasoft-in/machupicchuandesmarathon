---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, useTranslatedPath } from '../../utils/i18n';
import PageHeader from '../../components/PageHeader';
import TourGrid from '../../components/TourGrid';

import PremiumCTA from '../../components/PremiumCTA.astro';
export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}

const { lang: rawLang } = Astro.params;
const lang = rawLang as 'en' | 'es';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const tours = await getCollection('tours');
const otherTours = tours
  .map(t => t.data)
  .filter(t => t.category === 'other-treks');
---

<Layout title={`${t('nav.other')} | Machu Picchu Andes Marathon`} lang={lang}>
  <PageHeader 
    client:load
    lang={lang}
    title={lang === 'en' ? 'Other' : 'Otros'}
    titleAccent={lang === 'en' ? 'Treks' : 'Treks'}
    subtitle={lang === 'en' ? "Unique and specialized treks for the adventurous spirit." : "Treks únicos y especializados para el espíritu aventurero."}
    bgImage="/images/hero.webp"
  />

  <section class="section">
    <div class="container">
      <TourGrid client:visible lang={lang} tours={otherTours} />
    </div>
  </section>

  <PremiumCTA lang={lang} />
</Layout>


