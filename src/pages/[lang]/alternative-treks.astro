---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, useTranslatedPath } from '../../utils/i18n';
import PageHeader from '../../components/PageHeader';
import TourGrid from '../../components/TourGrid';


export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}

const { lang: rawLang } = Astro.params;
const lang = rawLang as 'en' | 'es';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const tours = await getCollection('tours');
const altTours = tours
  .map(t => t.data)
  .filter(t => t.category === 'alternative-treks');
---

<Layout title={`${t('nav.alternative')} | Machu Picchu Andes Marathon`} lang={lang}>
  <PageHeader 
    client:load
    lang={lang}
    title={lang === 'en' ? 'Alternative' : 'Treks'}
    titleAccent={lang === 'en' ? 'Treks' : 'Alternativos'}
    subtitle={lang === 'en' ? "Beyond the beaten path. Discover the hidden spirits of the Andes through our curated alternative routes." : "Más allá de las rutas comunes. Descubre los espíritus ocultos de los Andes a través de nuestras rutas alternativas curadas."}
    bgImage="/images/hero.webp"
  />

  <section class="section">
    <div class="container">
      <TourGrid client:visible lang={lang} tours={altTours} />
    </div>
  </section>


</Layout>


