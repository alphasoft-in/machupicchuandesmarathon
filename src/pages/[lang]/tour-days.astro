---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, useTranslatedPath } from '../../utils/i18n';
import PageHeader from '../../components/PageHeader';
import TourGrid from '../../components/TourGrid';

import BookingCTA from '../../components/BookingCTA';
export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}

const { lang: rawLang } = Astro.params;
const lang = rawLang as 'en' | 'es';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const tours = await getCollection('tours');
const dailyTours = tours
  .map(t => t.data)
  .filter(t => t.category === 'tour-days');
const title = t('nav.daily');
const description = lang === 'en' ? "Short immersions, deep connections. Experience the highlights of Cusco and the Sacred Valley in a single day." : "Inmersiones cortas, conexiones profundas. Experimenta los puntos más destacados de Cusco y el Valle Sagrado en un solo día.";
const image = "/images/tour-diarios/bg-tour-diarios.avif";
---

<Layout title={title} description={description} image={image} lang={lang}>
  <PageHeader 
    client:load
    lang={lang}
    title={lang === 'en' ? 'Daily' : 'Tours de'}
    titleAccent={lang === 'en' ? 'Tours' : 'un Día'}
    subtitle={description}
    bgImage={image}
  />

  <section class="py-10">
    <div class="container">
      <TourGrid client:visible lang={lang} tours={dailyTours} />
    </div>
  </section>

  <BookingCTA client:visible lang={lang} />
</Layout>


