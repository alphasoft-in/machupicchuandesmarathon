---
import Layout from '../../../layouts/Layout.astro';
import { Clock, Users, Baby, Train, ArrowRight, Star } from 'lucide-react';
import { getCollection } from 'astro:content';
import { useTranslations, useTranslatedPath } from '../../../utils/i18n';
import TourDetailsTabs from '../../../components/TourDetailsTabs';
import BookingSidebar from '../../../components/BookingSidebar';
import BookingCTA from '../../../components/BookingCTA.astro';

export async function getStaticPaths() {
  const tours = await getCollection('tours');
  return ['en', 'es'].flatMap(lang => 
    tours.map(tour => ({
      params: { lang, slug: tour.data.slug },
      props: { tour: tour.data, lang },
    }))
  );
}

const { tour, lang: rawLang } = Astro.props;
const lang = rawLang as 'en' | 'es';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Get tour content for current language
const content = tour[lang as keyof typeof tour] as any;

const allTours = await getCollection('tours');
const recommendations = allTours
  .filter(t => t.data.slug !== tour.slug)
  .sort(() => Math.random() - 0.5)
  .slice(0, 4)
  .map(t => t.data);
---

<Layout title={`${content.title} | Machu Picchu Andes Marathon`} lang={lang}>
  <section class="relative min-h-[75vh] flex items-center justify-center pt-[140px] sm:pt-[180px] pb-16 overflow-hidden bg-cover bg-center" style={`background-image: url(${tour.image})`}>
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-[#0e3b2e]/90 z-10"></div>
    
    <div class="container relative z-20 px-6 max-w-[1000px] text-center text-white">
      <div class="flex flex-col items-center animate-in fade-in slide-in-from-bottom-5 duration-1000">
        <span class="inline-block px-3 py-0.5 rounded-full bg-secondary text-white text-[0.6rem] font-bold uppercase tracking-[1.5px] mb-4 shadow-md">
          {content.tag}
        </span>
        
        <h1 class="serif text-[clamp(2rem,6vw,4.5rem)] leading-[1.1] mb-8 text-white drop-shadow-2xl">
          {content.title}
        </h1>
        
        <p class="text-[0.9rem] sm:text-[1.05rem] leading-relaxed text-white/90 max-w-[800px] mx-auto mb-12 font-light italic line-clamp-3 sm:line-clamp-4">
          "{content.description}"
        </p>
        
        <div class="grid grid-cols-4 gap-1 sm:gap-8 w-full max-w-[950px] bg-white/5 backdrop-blur-md p-3 sm:p-8 rounded-[20px] sm:rounded-[30px] border border-white/10 shadow-2xl">
          <div class="flex flex-col items-center gap-1 sm:gap-2">
            <div class="w-7 h-7 sm:w-10 sm:h-10 rounded-full bg-white/10 flex items-center justify-center text-white mb-0.5 sm:mb-1">
              <Clock size={14} class="sm:w-[20px] sm:h-[20px]" />
            </div>
            <div class="text-center">
              <span class="block text-[0.45rem] sm:text-[0.6rem] font-bold uppercase tracking-widest text-white/60 mb-0.5">{lang === 'en' ? 'Duration' : 'Duración'}</span>
              <span class="text-[0.65rem] sm:text-base font-semibold whitespace-nowrap text-white">{content.duration}</span>
            </div>
          </div>
          
          <div class="flex flex-col items-center gap-1 sm:gap-2">
            <div class="w-7 h-7 sm:w-10 sm:h-10 rounded-full bg-white/10 flex items-center justify-center text-white mb-0.5 sm:mb-1">
              <Users size={14} class="sm:w-[20px] sm:h-[20px]" />
            </div>
            <div class="text-center">
              <span class="block text-[0.45rem] sm:text-[0.6rem] font-bold uppercase tracking-widest text-white/60 mb-0.5">{lang === 'en' ? 'Group' : 'Grupo'}</span>
              <span class="text-[0.65rem] sm:text-base font-semibold whitespace-nowrap text-white">{content.maxPeople || '12'}{lang === 'en' ? ' Max' : ' Máx'}</span>
            </div>
          </div>
          
          <div class="flex flex-col items-center gap-1 sm:gap-2">
            <div class="w-7 h-7 sm:w-10 sm:h-10 rounded-full bg-white/10 flex items-center justify-center text-white mb-0.5 sm:mb-1">
              <Baby size={14} class="sm:w-[20px] sm:h-[20px]" />
            </div>
            <div class="text-center">
              <span class="block text-[0.45rem] sm:text-[0.6rem] font-bold uppercase tracking-widest text-white/60 mb-0.5">{lang === 'en' ? 'Age' : 'Edad'}</span>
              <span class="text-[0.65rem] sm:text-base font-semibold whitespace-nowrap text-white">{content.minAge || '6'}+</span>
            </div>
          </div>
          
          <div class="flex flex-col items-center gap-1 sm:gap-2">
            <div class="w-7 h-7 sm:w-10 sm:h-10 rounded-full bg-white/10 flex items-center justify-center text-white mb-0.5 sm:mb-1">
              <Train size={14} class="sm:w-[20px] sm:h-[20px]" />
            </div>
            <div class="text-center">
              <span class="block text-[0.45rem] sm:text-[0.6rem] font-bold uppercase tracking-widest text-white/60 mb-0.5">{lang === 'en' ? 'Pickup' : 'Traslado'}</span>
              <span class="text-[0.65rem] sm:text-base font-semibold whitespace-nowrap text-white">{content.pickup || (lang === 'en' ? 'Incl.' : 'Incl.')}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-2 sm:pt-12 sm:pb-8">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-20">
      <main class="flex-1 min-w-0">
        <TourDetailsTabs client:load lang={lang} content={content} tour={tour} />
      </main>

      <aside class="w-full lg:w-[380px] shrink-0">
        <div class="lg:sticky lg:top-[120px]">
          <BookingSidebar client:load lang={lang} tour={tour} />
        </div>
      </aside>
    </div>
  </div>

  <!-- Related Experiences -->
  <section class="bg-slate-50/50 py-8 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <h2 class="serif text-3xl text-[#0e3b2e] mb-2">{lang === 'en' ? 'Related Experiences' : 'Experiencias Relacionadas'}</h2>
        <p class="text-slate-500">{lang === 'en' ? 'Explore more wonders of the Andes.' : 'Explora más maravillas de los Andes.'}</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {recommendations.map((rec: any) => {
          const recContent = rec[lang as keyof typeof rec] as any;
          const tourLink = translatePath(`/tours/${rec.slug}`);
          return (
            <div class="group bg-white rounded-[32px] overflow-hidden border border-slate-100 shadow-sm transition-all duration-500 hover:shadow-xl hover:-translate-y-1 flex flex-col">
              <a href={tourLink} class="aspect-[4/3] overflow-hidden block">
                <img 
                  src={rec.image} 
                  alt={recContent?.title || 'Tour'} 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
              </a>
              <div class="p-6 flex flex-col flex-1">
                <span class="inline-block text-[0.65rem] font-bold text-secondary uppercase tracking-widest mb-2">{recContent?.tag}</span>
                <h3 class="serif text-lg text-[#0e3b2e] mb-2 line-clamp-2 min-h-[3.5rem] leading-tight">{recContent?.title}</h3>
                
                <div class="flex justify-between items-center pb-6 border-b border-slate-50 mb-6">
                  <span class="text-sm font-medium text-slate-500">{recContent?.duration}</span>
                  <span class="text-lg font-black text-[#0e3b2e]">{rec.price}</span>
                </div>

                <div class="mt-auto space-y-3">
                  <a 
                    href="https://wa.me/51912845941" 
                    target="_blank"
                    class="block w-full py-3.5 rounded-2xl bg-[#0e3b2e] text-white text-center text-xs font-black uppercase tracking-widest transition-all hover:bg-[#0e3b2e]/90 shadow-md shadow-emerald-100"
                  >
                    {lang === 'en' ? 'Enquire Now' : 'Consultar Ahora'}
                  </a>
                  <a 
                    href={tourLink}
                    class="block w-full py-3.5 rounded-2xl border-2 border-slate-100 text-slate-600 text-center text-xs font-black uppercase tracking-widest transition-all hover:bg-slate-50 hover:border-slate-200"
                  >
                    {lang === 'en' ? 'View Itinerary' : 'Ver Itinerario'}
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <BookingCTA lang={lang} />
</Layout>
