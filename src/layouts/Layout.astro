---
import '../styles/global.css';
import { Menu, X, Phone, Mail, Instagram, Facebook, Monitor, MapPin, ArrowRight } from 'lucide-astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Discover the ultimate adventure in the Andes with Machu Picchu Andes Marathon. Luxury tours, trail marathons, and cultural experiences in the heart of Peru." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Machu Picchu Andes Marathon</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Machu Picchu, Andes, Marathon, Peru, Travel Agency, Luxury Tours, Adventure Travel" />
  </head>
  <body>
    <!-- Premium Header -->
    <header class="header" id="header">
      <nav class="nav container">
        <a href="/" class="logo">
          <img src="/images/logo.png" alt="Machu Picchu Andes Marathon" class="logo-img" />
        </a>
        
        <ul class="nav-links" id="nav-menu">
          <li><a href="/">Home</a></li>
          <li><a href="/inca-trail">Inca Trail Tours</a></li>
          <li><a href="/alternative-treks">Alternative Treks</a></li>
          <li><a href="/tour-days">Tour Days</a></li>
          <li><a href="#contact" class="btn btn-primary">Book Now</a></li>
        </ul>

        <button class="mobile-toggle" id="mobile-toggle">
          <Menu class="icon open-icon" />
          <X class="icon close-icon hidden" />
        </button>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <!-- Professional Footer -->
    <footer class="footer">
      <div class="container footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo-link">
            <img src="/images/logo.png" alt="Logo" class="footer-logo" />
          </a>
          <p class="footer-tagline">Excellence in high-altitude experiences and trail running. Discover the soul of the Andes with experts.</p>
          <div class="social-links">
            <a href="#" aria-label="Instagram"><Instagram size="20" /></a>
            <a href="#" aria-label="Facebook"><Facebook size="20" /></a>
          </div>
        </div>

        <div class="footer-nav">
          <div class="footer-col">
            <h3>Expeditions</h3>
            <ul>
              <li><a href="/inca-trail">Inca Trail Tours</a></li>
              <li><a href="/alternative-treks">Alternative Treks</a></li>
              <li><a href="/tour-days">Daily Tours</a></li>
              <li><a href="#">Luxury Custom Trips</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h3>Resources</h3>
            <ul>
              <li><a href="#">Travel Insurance</a></li>
              <li><a href="#">Packing List</a></li>
              <li><a href="#">Health & Safety</a></li>
              <li><a href="#">FAQ</a></li>
            </ul>
          </div>
        </div>

        <div class="footer-newsletter">
          <h3>Newsletter</h3>
          <p>Subscribe to get travel tips and exclusive early-bird marathon offers.</p>
          <form class="newsletter-form">
            <input type="email" placeholder="Your email address" required />
            <button type="submit" aria-label="Subscribe"><ArrowRight size="20" /></button>
          </form>
        </div>
      </div>
      
      <div class="footer-bottom container">
        <div class="footer-legal">
          <p>&copy; {new Date().getFullYear()} Machu Picchu Andes Marathon. All rights reserved.</p>
          <div class="legal-links">
            <a href="#">Privacy Policy</a>
            <a href="#">Terms of Service</a>
          </div>
        </div>
      </div>
    </footer>

    <style>
      .header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        padding: 1.5rem 0;
        z-index: 1000;
        transition: var(--transition);
      }

      .header.scrolled {
        padding: 1rem 0;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        box-shadow: var(--shadow-md);
      }

      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        display: flex;
        align-items: center;
        z-index: 1001;
      }

      .logo-img {
        height: 60px;
        width: auto;
        transition: var(--transition);
        display: block;
      }

      .header.scrolled .logo-img {
        height: 50px;
      }

      .nav-links {
        display: flex;
        gap: 2.5rem;
        align-items: center;
      }

      .nav-links a {
        color: var(--text-light);
        font-weight: 500;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      .header.scrolled .nav-links a {
        color: var(--text-dark);
      }

      .nav-links a:hover {
        color: var(--secondary);
      }



      .mobile-toggle {
        display: none;
        background: none;
        border: none;
        color: var(--text-light);
        cursor: pointer;
      }

      .header.scrolled .mobile-toggle {
        color: var(--text-dark);
      }

      .close-icon.hidden, .open-icon.hidden {
        display: none;
      }

      .close-icon {
        display: block;
      }

      .close-icon.hidden {
        display: none;
      }

      /* Footer Styles */
      .footer {
        background: #051c14;
        color: var(--text-light);
        padding: 5rem 0 3rem;
        margin-top: 0;
      }

      .footer-grid {
        display: grid;
        grid-template-columns: 1.5fr 2fr 1.5fr;
        gap: 6rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 5rem;
      }

      .footer-brand {
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }

      .footer-logo {
        height: 70px;
        width: auto;
      }

      .footer-tagline {
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.8;
        font-size: 0.95rem;
      }

      .social-links {
        display: flex;
        gap: 1rem;
      }

      .social-links a {
        width: 45px;
        height: 45px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        transition: var(--transition);
      }

      .social-links a:hover {
        background: var(--secondary);
        transform: translateY(-5px);
      }

      .footer-nav {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
      }

      .footer h3 {
        font-size: 1.1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 2rem;
        color: var(--secondary);
      }

      .footer-col ul {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }

      .footer-col a {
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.95rem;
        transition: var(--transition);
      }

      .footer-col a:hover {
        color: white;
        padding-left: 5px;
      }

      .footer-newsletter {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .footer-newsletter p {
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.9rem;
        line-height: 1.6;
      }

      .newsletter-form {
        display: flex;
        gap: 0;
        background: rgba(255, 255, 255, 0.05);
        padding: 5px;
        border-radius: 60px;
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .newsletter-form input {
        background: none;
        border: none;
        padding: 0.75rem 1.5rem;
        color: white;
        flex-grow: 1;
        outline: none;
        font-family: inherit;
      }

      .newsletter-form button {
        background: var(--secondary);
        color: white;
        border: none;
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: var(--transition);
      }

      .newsletter-form button:hover {
        background: var(--accent);
        transform: scale(1.05);
      }

      .footer-bottom {
        padding-top: 3rem;
      }

      .footer-legal {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.4);
      }

      .legal-links {
        display: flex;
        gap: 2rem;
      }

      .legal-links a:hover {
        color: white;
      }

      @media (max-width: 1024px) {
        .footer-grid {
          grid-template-columns: 1fr 1fr;
          gap: 4rem;
        }
        .footer-newsletter {
          grid-column: span 2;
        }
      }

      @media (max-width: 768px) {
        .mobile-toggle {
          display: block;
        }

        .nav-links {
          position: fixed;
          top: 0;
          right: -100%;
          width: 80%;
          height: 100vh;
          background: white;
          flex-direction: column;
          padding: 6rem 2rem;
          transition: var(--transition);
          box-shadow: -10px 0 30px rgba(0, 0, 0, 0.1);
          z-index: 1000;
        }

        .nav-links.active {
          right: 0;
        }

        .nav-links a {
          color: var(--text-dark) !important;
          font-size: 1.25rem;
        }

        .footer-grid {
          grid-template-columns: 1fr;
        }
        .footer-newsletter {
          grid-column: span 1;
        }
        .footer-nav {
          grid-template-columns: 1fr;
        }
        .footer-legal {
          flex-direction: column;
          gap: 1.5rem;
          text-align: center;
        }
      }
    </style>

    <script>
      const header = document.getElementById('header');
      const mobileToggle = document.getElementById('mobile-toggle');
      const navMenu = document.getElementById('nav-menu');

      if (header) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 50) {
            header.classList.add('scrolled');
          } else {
            header.classList.remove('scrolled');
          }
        });
      }

      if (mobileToggle && navMenu) {
        mobileToggle.addEventListener('click', () => {
          navMenu.classList.toggle('active');
          const openIcon = mobileToggle.querySelector('.open-icon');
          const closeIcon = mobileToggle.querySelector('.close-icon');
          
          if (openIcon) openIcon.classList.toggle('hidden');
          if (closeIcon) closeIcon.classList.toggle('hidden');
        });
      }
    </script>
  </body>
</html>
