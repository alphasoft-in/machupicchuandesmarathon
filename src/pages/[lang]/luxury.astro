---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, useTranslatedPath } from '../../utils/i18n';
import PageHeader from '../../components/PageHeader';
import TourGrid from '../../components/TourGrid';

import BookingCTA from '../../components/BookingCTA';
export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}

const { lang: rawLang } = Astro.params;
const lang = rawLang as 'en' | 'es';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const allTours = await getCollection('tours');
const luxuryTours = allTours
  .map(t => t.data)
  .filter(t => t.en.tag === 'Luxury');
---

<Layout title={`${t('nav.luxury')} | Machu Picchu Andes Marathon`} lang={lang}>
  <PageHeader 
    client:load
    lang={lang}
    title={lang === 'en' ? 'Luxury' : 'Experiencias'}
    titleAccent={lang === 'en' ? 'Experiences' : 'de Lujo'}
    subtitle={lang === 'en' ? "Indulge in the extraordinary. Bespoke journeys that blend high-altitude adventure with world-class comfort and elegance." : "Entrégate a lo extraordinario. Viajes a medida que combinan la aventura de alta montaña con el confort y la elegancia de clase mundial."}
    bgImage="/images/train.webp"
  />

  <section class="py-10">
    <div class="container">
      <TourGrid client:visible lang={lang} tours={luxuryTours} />
    </div>
  </section>

  <BookingCTA client:visible lang={lang} />
</Layout>
