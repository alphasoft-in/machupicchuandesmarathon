---
import Layout from '../../../layouts/Layout.astro';
import { Clock, Users, Baby, Train, ArrowRight, Star } from 'lucide-react';
import { getCollection } from 'astro:content';
import { useTranslations, useTranslatedPath } from '../../../utils/i18n.js';
import TourDetailsTabs from '../../../components/TourDetailsTabs';
import BookingSidebar from '../../../components/BookingSidebar';
import BookingForm from '../../../components/BookingForm';


export async function getStaticPaths() {
  const tours = await getCollection('tours');
  return ['en', 'es'].flatMap(lang => 
    tours.map(tour => ({
      params: { lang, slug: tour.data.slug },
      props: { tour: tour.data, lang },
    }))
  );
}

const { tour, lang: rawLang } = Astro.props;
const lang = rawLang as 'en' | 'es';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Get tour content for current language
const content = tour[lang as keyof typeof tour] as any;

const allTours = await getCollection('tours');
const recommendations = allTours
  .filter(t => t.data.slug !== tour.slug)
  .sort(() => Math.random() - 0.5)
  .slice(0, 4)
  .map(t => t.data);
---

<Layout title={`${content.title} | Machu Picchu Andes Marathon`} lang={lang}>
  <section class="relative min-h-[75vh] flex items-center justify-center pt-[140px] sm:pt-[180px] pb-16 overflow-hidden bg-cover bg-center" style={`background-image: url(${tour.image})`}>
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-[#0e3b2e]/90 z-10"></div>
    
    <div class="container relative z-20 px-6 max-w-[1000px] text-center text-white">
      <div class="flex flex-col items-center animate-in fade-in slide-in-from-bottom-5 duration-1000">
        <span class="inline-block px-3 py-0.5 rounded-full bg-secondary text-white text-[0.6rem] font-bold uppercase tracking-[1.5px] mb-4 shadow-md">
          {content.tag}
        </span>
        
        <h1 class="serif text-[clamp(1.8rem,5vw,3.2rem)] leading-[1.2] mb-6 text-white drop-shadow-2xl">
          {content.title}
        </h1>
        
        <p class="text-[0.85rem] sm:text-[1rem] leading-relaxed text-white/80 max-w-[700px] mx-auto mb-10 font-light italic line-clamp-3 sm:line-clamp-4">
          "{content.description}"
        </p>
        
        <div class="grid grid-cols-4 gap-1 sm:gap-8 w-full max-w-[1000px] 2xl:max-w-[1200px] bg-white/5 backdrop-blur-md p-4 sm:p-8 2xl:p-10 rounded-[20px] sm:rounded-[30px] border border-white/10 shadow-2xl mx-auto">
          <div class="flex flex-col items-center gap-1 sm:gap-3">
            <div class="w-8 h-8 sm:w-12 sm:h-12 2xl:w-14 2xl:h-14 rounded-full bg-white/10 flex items-center justify-center text-white mb-0.5 sm:mb-1">
              <Clock size={16} class="sm:w-[24px] sm:h-[24px] 2xl:w-[28px] 2xl:h-[28px]" />
            </div>
            <div class="text-center">
              <span class="block text-[0.45rem] sm:text-[0.7rem] 2xl:text-[0.8rem] font-bold uppercase tracking-widest text-white/60 mb-0.5">{lang === 'en' ? 'Duration' : 'Duración'}</span>
              <span class="text-[0.65rem] sm:text-lg 2xl:text-xl font-semibold whitespace-nowrap text-white">{content.duration}</span>
            </div>
          </div>
          
          <div class="flex flex-col items-center gap-1 sm:gap-3">
            <div class="w-8 h-8 sm:w-12 sm:h-12 2xl:w-14 2xl:h-14 rounded-full bg-white/10 flex items-center justify-center text-white mb-0.5 sm:mb-1">
              <Users size={16} class="sm:w-[24px] sm:h-[24px] 2xl:w-[28px] 2xl:h-[28px]" />
            </div>
            <div class="text-center">
              <span class="block text-[0.45rem] sm:text-[0.7rem] 2xl:text-[0.8rem] font-bold uppercase tracking-widest text-white/60 mb-0.5">{lang === 'en' ? 'Group' : 'Grupo'}</span>
              <span class="text-[0.65rem] sm:text-lg 2xl:text-xl font-semibold whitespace-nowrap text-white">{content.maxPeople || '12'}{lang === 'en' ? ' Max' : ' Máx'}</span>
            </div>
          </div>
          
          <div class="flex flex-col items-center gap-1 sm:gap-3">
            <div class="w-8 h-8 sm:w-12 sm:h-12 2xl:w-14 2xl:h-14 rounded-full bg-white/10 flex items-center justify-center text-white mb-0.5 sm:mb-1">
              <Baby size={16} class="sm:w-[24px] sm:h-[24px] 2xl:w-[28px] 2xl:h-[28px]" />
            </div>
            <div class="text-center">
              <span class="block text-[0.45rem] sm:text-[0.7rem] 2xl:text-[0.8rem] font-bold uppercase tracking-widest text-white/60 mb-0.5">{lang === 'en' ? 'Age' : 'Edad'}</span>
              <span class="text-[0.65rem] sm:text-lg 2xl:text-xl font-semibold whitespace-nowrap text-white">{content.minAge || '6'}+</span>
            </div>
          </div>
          
          <div class="flex flex-col items-center gap-1 sm:gap-3">
            <div class="w-8 h-8 sm:w-12 sm:h-12 2xl:w-14 2xl:h-14 rounded-full bg-white/10 flex items-center justify-center text-white mb-0.5 sm:mb-1">
              <Train size={16} class="sm:w-[24px] sm:h-[24px] 2xl:w-[28px] 2xl:h-[28px]" />
            </div>
            <div class="text-center">
              <span class="block text-[0.45rem] sm:text-[0.7rem] 2xl:text-[0.8rem] font-bold uppercase tracking-widest text-white/60 mb-0.5">{lang === 'en' ? 'Pickup' : 'Traslado'}</span>
              <span class="text-[0.65rem] sm:text-lg 2xl:text-xl font-semibold whitespace-nowrap text-white">{content.pickup || (lang === 'en' ? 'Incl.' : 'Incl.')}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-2 sm:pt-12 sm:pb-8">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-20">
      <main class="flex-1 min-w-0">
        <TourDetailsTabs client:load lang={lang} content={content} tour={tour} />
      </main>

      <aside class="w-full lg:w-[380px] shrink-0">
        <div class="lg:sticky lg:top-[120px]">
          <BookingSidebar client:load lang={lang} tour={tour} />
        </div>
      </aside>
    </div>
  </div>

  <!-- Related Experiences -->
  <section class="bg-slate-50/50 py-8 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <h2 class="serif text-3xl text-[#0e3b2e] mb-2">{lang === 'en' ? 'Related Experiences' : 'Experiencias Relacionadas'}</h2>
        <p class="text-slate-500">{lang === 'en' ? 'Explore more wonders of the Andes.' : 'Explora más maravillas de los Andes.'}</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {recommendations.map((rec: any) => {
          const recContent = rec[lang as keyof typeof rec] as any;
          const tourLink = translatePath(`/tours/${rec.slug}`);
          return (
            <div class="group bg-white rounded-[32px] overflow-hidden border border-slate-100 shadow-sm transition-all duration-500 hover:shadow-xl hover:-translate-y-1 flex flex-col">
              <a href={tourLink} class="aspect-[4/3] overflow-hidden block">
                <img 
                  src={rec.image} 
                  alt={recContent?.title || 'Tour'} 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
              </a>
              <div class="p-6 flex flex-col flex-1">
                <span class="inline-block text-[0.6rem] font-bold text-secondary uppercase tracking-[2px] mb-2">{recContent?.tag}</span>
                <h3 class="serif text-base sm:text-lg text-[#0e3b2e] mb-4 line-clamp-2 min-h-[3rem] sm:min-h-[3.5rem] leading-[1.3]">{recContent?.title}</h3>
                
                <div class="flex justify-between items-end pb-4 border-b border-slate-50 mb-6">
                  <div class="flex flex-col">
                    <span class="text-[0.65rem] uppercase text-slate-400 font-bold mb-1">{lang === 'en' ? 'Duration' : 'Duración'}</span>
                    <span class="text-xs sm:text-sm font-bold text-slate-600">{recContent?.duration}</span>
                  </div>
                  <div class="flex flex-col items-end">
                    <span class="text-[0.65rem] uppercase text-slate-400 font-bold mb-1">{lang === 'en' ? 'From' : 'Desde'}</span>
                    <span class="text-base sm:text-lg font-black text-[#0e3b2e] leading-none">{rec.price}</span>
                  </div>
                </div>

                <div class="mt-auto space-y-3">
                  <a 
                    href={`https://wa.me/51993187203?text=${encodeURIComponent(lang === 'en' ? `Hello, I'd like to consult about the tour: ${recContent.title}` : `Hola, me gustaría consultar sobre el tour: ${recContent.title}`)}`}
                    target="_blank"
                    class="flex items-center justify-center gap-2 w-full py-3.5 rounded-2xl bg-[#0e3b2e] text-white text-center text-xs font-black uppercase tracking-widest transition-all hover:bg-[#0e3b2e]/90 shadow-md shadow-emerald-100"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="shrink-0">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.06-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                    </svg>
                    {lang === 'en' ? 'Enquire Now' : 'Consultar Ahora'}
                  </a>
                  <a 
                    href={tourLink}
                    class="flex items-center justify-center gap-2 w-full py-3.5 rounded-2xl border-2 border-slate-100 text-slate-600 text-center text-xs font-black uppercase tracking-widest transition-all hover:bg-slate-50 hover:border-slate-200"
                  >
                    {lang === 'en' ? 'View Itinerary' : 'Ver Itinerario'}
                    <ArrowRight size={14} className="shrink-0" />
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
  <section class="section bg-muted">
    <div class="container max-w-2xl">
      <div class="text-center mb-10">
        <h2 class="serif text-4xl text-primary mb-4">{t('booking.title')}</h2>
        <p class="text-slate-500">{t('booking.subtitle')}</p>
      </div>
      <BookingForm client:visible lang={lang} />
    </div>
  </section>
</Layout>
