---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Mail, Phone, MapPin, CheckCircle, Globe, Users } from 'lucide-react';
import { useTranslations, useTranslatedPath } from '../../utils/i18n';
import Hero from '../../components/Hero';
import CategoryGrid from '../../components/CategoryGrid';
import TourGrid from '../../components/TourGrid';
import TestimonialsSlider from '../../components/TestimonialsSlider';
import BookingForm from '../../components/BookingForm';
import BookingCTA from '../../components/BookingCTA.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}

const { lang: rawLang } = Astro.params;
const lang = rawLang as 'en' | 'es';

const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Data fetching
const allTours = await getCollection('tours');
const featuredTours = allTours
  .map(t => t.data)
  .slice(0, 6);

const categories = [
  {
    title: t('nav.inca'),
    desc: lang === 'en' 
      ? "Discover the legendary path of the Incas. A unique journey through history and breathtaking landscapes." 
      : "Descubre el legendario camino de los Incas. Un viaje único a través de la historia y paisajes impresionantes.",
    image: "/images/hero.webp",
    link: "/inca-trail",
    accent: "#0e3b2e"
  },
  {
    title: t('nav.alternative'),
    desc: lang === 'en'
      ? "Explore off-the-beaten-path trails. Salkantay, Choquequirao, and more adventure awaits."
      : "Explora rutas fuera de lo común. Salkantay, Choquequirao y más aventuras te esperan.",
    image: "/images/salkantay.webp",
    link: "/alternative-treks",
    accent: "#fc6111"
  },
  {
    title: t('nav.daily'),
    desc: lang === 'en'
      ? "Perfect daily excursions from Cusco and the Sacred Valley. Culture, adventure, and history in a single day."
      : "Excursiones diarias perfectas desde Cusco y el Valle Sagrado. Cultura, aventura e historia en un solo día.",
    image: "/images/sacred-valley.webp",
    link: "/tour-days",
    accent: "#ff8c42"
  }
];

const testimonials = [
  {
    rating: 5,
    text: lang === 'en' 
      ? "The Premium Inca Trail was life-changing. The glamping tents and the private chef felt like a 5-star hotel in the middle of the mountains." 
      : "El Camino Inca Premium cambió mi vida. Las carpas glamping y el chef privado se sentían como un hotel de 5 estrellas en medio de las montañas.",
    client: "Sarah Jenkins, UK"
  },
  {
    rating: 5,
    text: lang === 'en'
      ? "Excellence in every step. Our guide knew every hidden stone and told stories that brought the ruins to life."
      : "Excelencia en cada paso. Nuestro guía conocía cada piedra oculta y contaba historias que daban vida a las ruinas.",
    client: "Marc Dubois, France"
  },
  {
    rating: 5,
    text: lang === 'en'
      ? "Best decision of my life. The local expertise of Machu Picchu Andes Marathon is unmatched. They really care about the culture."
      : "La mejor decisión de mi vida. El conocimiento local de Machu Picchu Andes Marathon es inigualable. Realmente se preocupan por la cultura.",
    client: "Elena Rossi, Italy"
  },
  {
    rating: 5,
    text: lang === 'en'
      ? "Unforgettable experience. The attention to detail on the Salkantay Trek was beyond my expectations."
      : "Experiencia inolvidable. La atención al detalle en el Salkantay Trek superó mis expectativas.",
    client: "James Wilson, Australia"
  }
];
---

<Layout title={t('hero.title')} lang={lang}>
  <Hero 
    client:load 
    lang={lang} 
    subtitle={t('hero.subtitle')} 
    ctaText={t('hero.cta')} 
    categoryPath={translatePath('/inca-trail')} 
  />

  <section id="categories" class="section categories" style="padding-bottom: 0;">
    <CategoryGrid client:visible lang={lang} categories={categories} translatePath={translatePath} />
  </section>

  <section id="featured-tours" class="section bg-light" style="padding-top: 0;">
    <div class="container">
      <div style="text-align: center; margin-bottom: 3rem; width: 100%;">
        <h2 class="section-title serif" style="margin-bottom: 1.5rem; text-align: center;">{t('home.featured.title')}</h2>
        <p class="section-subtitle" style="max-width: 700px; margin-left: auto; margin-right: auto; text-align: center;">
          {t('home.featured.subtitle')}
        </p>
      </div>
      
      <TourGrid client:visible lang={lang} tours={featuredTours} />
      
    </div>
  </section>

  <!-- About / Why Us (Keep structural HTML in Astro, but using React icons) -->
  <section id="about" class="section bg-muted">
    <div class="container about-grid">
      <div class="about-content">
        <h2 class="serif">{lang === 'en' ? 'Excellence in Every Step' : 'Excelencia en cada paso'}</h2>
        <p>{lang === 'en' ? 'With over 15 years of experience in the Peruvian Andes, we specialize in high-altitude logistics and luxury travel management. Our mission is to provide life-changing experiences while preserving the cultural and natural heritage of the Incas.' : 'Con más de 15 años de experiencia en los Andes peruanos, nos especializamos en logística de gran altitud y gestión de viajes de lujo. Nuestra misión es brindar experiencias que cambien la vida mientras preservamos el patrimonio cultural y natural de los Incas.'}</p>
        
        <ul class="stats-grid">
          <li>
            <div class="stat-icon"><Globe size={24} /></div>
            <div>
              <strong>{lang === 'en' ? 'Local Expertise' : 'Experiencia Local'}</strong>
              <p>{lang === 'en' ? '100% Peruvian owned and operated company.' : 'Empresa 100% peruana.'}</p>
            </div>
          </li>
          <li>
            <div class="stat-icon"><Users size={24} /></div>
            <div>
              <strong>{lang === 'en' ? 'Small Groups' : 'Grupos Pequeños'}</strong>
              <p>{lang === 'en' ? 'Personalized attention for an intimate experience.' : 'Atención personalizada para una experiencia íntima.'}</p>
            </div>
          </li>
          <li>
            <div class="stat-icon"><MapPin size={24} /></div>
            <div>
              <strong>{lang === 'en' ? 'Hidden Paths' : 'Senderos Ocultos'}</strong>
              <p>{lang === 'en' ? 'Access to restricted and off-the-beaten-path locations.' : 'Acceso a lugares restringidos y fuera de las rutas comunes.'}</p>
            </div>
          </li>
        </ul>
      </div>
      <div class="about-image">
        <img src="/images/marathon.webp" alt="Incan Trail" class="rounded-img shadow-lg" />
      </div>
    </div>
  </section>

  <TestimonialsSlider client:visible lang={lang} testimonials={testimonials} />

  <!-- Booking CTA Section -->
  <BookingCTA lang={lang} />
</Layout>
