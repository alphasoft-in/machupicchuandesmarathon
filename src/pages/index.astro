---
import '../styles/global.css';
import { Instagram, Facebook, Mail, MapPin } from 'lucide-astro';
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Próximamente | Machu Picchu Andes Marathon</title>
</head>
<body>
    <div class="coming-soon">
        <div class="background"></div>
        <div class="overlay"></div>
        
        <header class="header">
            <div class="logo-container">
                <img src="/images/logo.png" alt="Logo" class="logo-img" />
            </div>
        </header>

        <main class="content animate-fade-in">
            <h1 class="serif">Próximamente</h1>
            <p>Estamos preparando la experiencia de viaje y aventura más mística de los Andes. Prepárate para lo extraordinario.</p>
            
            <div class="countdown-placeholder">
                <div class="status-badge">Explorando Nuevas Rutas...</div>
            </div>

            <div class="newsletter">
                <form>
                  <input type="email" placeholder="Tu correo electrónico" />
                  <button type="button">Notificarme</button>
                </form>
            </div>
        </main>

        <footer class="footer">
            <div class="socials">
                <a href="#"><Instagram size="20" /></a>
                <a href="#"><Facebook size="20" /></a>
                <a href="#"><Mail size="20" /></a>
            </div>
            <div class="location">
                <MapPin size="16" /> Cusco, Perú
            </div>
        </footer>
    </div>

    <style>
        .coming-soon {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
            background: #000;
            color: #fff;
            position: relative;
            overflow: hidden;
            text-align: center;
            padding: 2rem;
        }

        .background {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('/images/hero.png');
            background-size: cover;
            background-position: center;
            opacity: 0.6;
            filter: grayscale(30%);
            transition: transform 10s linear;
        }

        .coming-soon:hover .background {
            transform: scale(1.1);
        }

        .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, transparent 0%, rgba(0,0,0,0.8) 100%);
        }

        .header, .footer, .content {
            position: relative;
            z-index: 10;
        }

        .logo-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
        }

        .logo-img {
            width: 220px;
            height: auto;
            border-radius: 8px;
        }

        .content {
            max-width: 800px;
            width: 100%;
            padding: 0 1rem;
        }

        h1 {
            font-size: clamp(2.5rem, 12vw, 5.5rem);
            margin-bottom: 1.5rem;
            letter-spacing: -2px;
            line-height: 1.1;
        }

        p {
            font-size: clamp(1rem, 4vw, 1.25rem);
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: clamp(1.5rem, 6vw, 3rem);
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
            line-height: 1.6;
        }

        .status-badge {
            display: inline-block;
            padding: 0.6rem 2rem;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(10, 137, 58, 0.5);
            color: #fff;
            border-radius: 50px;
            font-size: clamp(0.7rem, 2vw, 0.8rem);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: clamp(2rem, 8vw, 3rem);
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(10, 137, 58, 0.3); }
            70% { box-shadow: 0 0 0 10px rgba(10, 137, 58, 0); }
            100% { box-shadow: 0 0 0 0 rgba(10, 137, 58, 0); }
        }

        .newsletter {
            margin-top: 1rem;
        }

        .newsletter form {
            display: flex;
            gap: 12px;
            max-width: 480px;
            margin: 0 auto;
        }

        .newsletter input {
            flex: 1;
            padding: 1.1rem 1.5rem;
            border-radius: 12px;
            border: 1.5px solid rgba(255, 255, 255, 0.5);
            background: rgba(0, 0, 0, 0.4);
            color: #fff;
            backdrop-filter: blur(10px);
            font-size: clamp(0.9rem, 3vw, 1rem);
            outline: none;
            transition: var(--transition);
        }

        .newsletter input:focus {
            background: rgba(0, 0, 0, 0.6);
            border-color: var(--primary);
            box-shadow: 0 0 20px rgba(10, 137, 58, 0.2);
        }

        .newsletter input::placeholder {
            color: rgba(255, 255, 255, 0.5);
        }

        .newsletter button {
            padding: 1rem 2.5rem;
            border-radius: 12px;
            border: none;
            background: var(--secondary);
            color: #fff;
            font-weight: 800;
            font-size: clamp(0.85rem, 2.5vw, 0.95rem);
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: var(--transition);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
        }

        .newsletter button:hover {
            background: var(--primary);
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(10, 137, 58, 0.3);
        }

        .footer {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            align-items: center;
            width: 100%;
        }

        .socials {
            display: flex;
            gap: clamp(1.5rem, 5vw, 2.5rem);
        }

        .socials a {
            color: rgba(255,255,255,0.5);
            transition: var(--transition);
        }

        .socials a:hover {
            color: var(--secondary);
            transform: translateY(-3px);
        }

        .location {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.4);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Responsive Improvements */
        @media (max-width: 640px) {
            .coming-soon {
                padding: 1.5rem 1rem;
                justify-content: space-around;
                gap: 2rem;
            }

            .logo-img {
                width: 140px;
            }

            .newsletter form {
                flex-direction: column;
                gap: 0.75rem;
            }

            .newsletter input, .newsletter button {
                width: 100%;
                padding: 1rem;
            }

            .background {
                opacity: 0.35;
                filter: grayscale(10%) brightness(0.6);
            }
        }

        @media (max-height: 700px) {
            .coming-soon {
                padding: 1rem;
                justify-content: center;
                gap: 1.5rem;
            }
            .logo-img {
                width: 100px;
            }
            .status-badge {
                margin-bottom: 1rem;
            }
            p { margin-bottom: 1.5rem; }
        }
    </style>
</body>
</html>
    </style>
</body>
</html>
