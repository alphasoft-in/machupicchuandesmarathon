---
import { ArrowRight } from 'lucide-react';

interface Category {
  title: string;
  desc: string;
  image: string;
  link: string;
  accent: string;
}

interface Props {
  lang: 'en' | 'es';
  categories: Category[];
  translatePath: (path: string) => string;
}

const { lang, categories, translatePath } = Astro.props;
---

<div class="container grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 mt-8">
  {categories.map((cat, index) => (
    <a 
      href={translatePath(cat.link)} 
      class="relative h-[520px] rounded-[30px] overflow-hidden flex flex-col justify-end p-12 text-white transition-all duration-300 group no-underline revealed-section"
      style={`animation-delay: ${index * 0.2}s`}
    >
      <div class="absolute inset-0 z-0">
        <img 
          src={cat.image} 
          alt={cat.title} 
          class="w-full h-full object-cover transition-transform duration-1000 ease-[cubic-bezier(0.19,1,0.22,1)] group-hover:scale-110"
        />
        <div 
          class="absolute inset-0 z-10 transition-all duration-300" 
          style={`background: linear-gradient(to top, ${cat.accent}ee, transparent)`}
        ></div>
      </div>
      <div class="relative z-20">
        <h2 class="serif text-3xl mb-3">{cat.title}</h2>
        <p class="text-white/80 mb-6 line-clamp-3">{cat.desc}</p>
        <span class="inline-flex items-center text-secondary font-bold uppercase tracking-wider text-sm">
          {lang === 'en' ? 'View Packages' : 'Ver Paquetes'} <ArrowRight size={18} class="ml-2 transition-transform duration-300 group-hover:translate-x-1" />
        </span>
      </div>
    </a>
  ))}
</div>

<style>
  .revealed-section {
    opacity: 0;
    transform: translateY(30px);
  }

  /* We use the global intersection observer class if available, 
     otherwise we can add a simple entry animation here */
  :global(section.revealed) .revealed-section {
    animation: fadeUp 0.8s ease-out forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
