---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, useTranslatedPath } from '../../utils/i18n';
import PageHeader from '../../components/PageHeader';
import TourGrid from '../../components/TourGrid';

import BookingCTA from '../../components/BookingCTA';
export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}

const { lang: rawLang } = Astro.params;
const lang = rawLang as 'en' | 'es';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const tours = await getCollection('tours');
const otherTours = tours
  .map(t => t.data)
  .filter(t => t.category === 'other-treks');
const title = t('nav.other');
const description = lang === 'en' ? "Unique and specialized treks for the adventurous spirit." : "Treks únicos y especializados para el espíritu aventurero.";
const image = "/images/other-treks/bg-other-treks.avif";
---

<Layout title={title} description={description} image={image} lang={lang}>
  <PageHeader 
    client:idle
    lang={lang}
    title={lang === 'en' ? 'Other' : 'Otros'}
    titleAccent={lang === 'en' ? 'Treks' : 'Treks'}
    subtitle={description}
    bgImage={image}
  />

  <section class="py-10">
    <div class="container">
      <TourGrid client:visible lang={lang} tours={otherTours} />
    </div>
  </section>

  <BookingCTA client:visible lang={lang} />
</Layout>


