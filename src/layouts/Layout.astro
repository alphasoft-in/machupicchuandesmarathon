---
import "../styles/global.css";
import { useTranslations, useTranslatedPath } from "../utils/i18n";
import Header from "../components/Header";
import Footer from "../components/Footer";

interface Props {
  title: string;
  description?: string;
  lang?: string;
  image?: string;
}

const lang = (Astro.currentLocale as "en" | "es") || "en";

const defaultDescEn = "Premier travel agency in Cusco with expert local guides. Specialized in trekking, Machu Picchu tours, and Inca Trail expeditions. Direct operator for authentic adventures.";
const defaultDescEs = "Agencia de viajes en Cusco con guía local experto. Especialistas en trekking, tours a Machu Picchu y Camino Inca. Operador directo para aventuras auténticas en los Andes.";

const defaultKwEn = "Travel agency in Cusco, Local Guide, Trekking Peru, Inca Trail Specialist, Machu Picchu tours, Direct operator Cusco, Best treks Cusco, Hiking Peru, Cusco tour operator, Adventure travel Peru";
const defaultKwEs = "Agencia de viajes en Cusco, Guía local, Trekking Peru, Camino Inca, Machu Picchu tours, Operador directo Cusco, Mejores treks Cusco, Senderismo Peru, Turismo Cusco, Viajes de aventura";

const {
  title,
  description = lang === 'es' ? defaultDescEs : defaultDescEn,
  image = "/images/og-default.jpg",
} = Astro.props;

const pageKeywords = lang === 'es' ? defaultKwEs : defaultKwEn;
const titleSuffix = lang === 'es' ? 'Agencia de Viajes en Cusco & Operador de Trekking' : 'Travel Agency in Cusco & Trekking Operator';

const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const currentPath = Astro.url.pathname;

// Helper to switch language
const otherLang = lang === "en" ? "es" : "en";
const switchPath = currentPath.includes(`/${lang}/`)
  ? currentPath.replace(`/${lang}/`, `/${otherLang}/`)
  : `/${otherLang}/`;

// Canonical URL
const siteUrl = "https://peruandestrekking.com";
const canonicalUrl = `${siteUrl}${currentPath}`;

// Hreflang URLs (i18n SEO)
const currentLangUrl = canonicalUrl;
const alternateLangUrl = `${siteUrl}${switchPath}`;

// Open Graph
const ogTitle = `${title} | Peru Andes Trekking`;
const ogDescription = description;
const ogUrl = canonicalUrl;
const ogImage = `${siteUrl}${image}`;
const ogSiteName = "Peru Andes Trekking";
const ogLocale = lang === "en" ? "en_US" : "es_ES";
---

<!doctype html>
<html lang={lang}>
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-PXZKQCHT');</script>
    <!-- End Google Tag Manager -->

    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon-nuevo.avif" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- SEO Basic -->
    <title>
      {title} | Peru Andes Trekking | {titleSuffix}
    </title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content={pageKeywords}
    />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang Tags for Multi-language SEO -->
    <link rel="alternate" hreflang={lang} href={currentLangUrl} />
    <link rel="alternate" hreflang={otherLang} href={alternateLangUrl} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={ogSiteName} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Schema -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "TravelAgency",
        name: "Peru Andes Trekking",
        description: description,
        url: siteUrl,
        logo: `${siteUrl}/images/logo.webp`,
        image: `${siteUrl}/images/hero.avif`,
        telephone: "+51 993 187 203",
        email: "info@peruandestrekking.com",
        address: {
          "@type": "PostalAddress",
          streetAddress: "Jr. Santa Rosa P7",
          addressLocality: "Cusco",
          addressRegion: "Cusco",
          addressCountry: "PE",
        },
        geo: {
          "@type": "GeoCoordinates",
          latitude: "-13.5319",
          longitude: "-71.9675",
        },
        sameAs: [
          "https://www.facebook.com/machupicchuandesmarathn",
          "https://instagram.com/machupicchu_andes",
          "https://www.tripadvisor.com.pe/UserReviewEdit-g294314-d28603761-Machupicchu_Andes_Marathon-Cusco_Cusco_Region.html",
        ],
        priceRange: "$$$",
      })}
    />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PXZKQCHT"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <Header
      client:load
      lang={lang}
      switchPath={switchPath}
      currentPath={currentPath}
    />

    <main>
      <slot />
    </main>

    <Footer client:load lang={lang} />

    <script>
      // Scroll Reveal Observer
      const observerOptions = {
        threshold: 0.1,
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
          }
        });
      }, observerOptions);

      document.querySelectorAll("section").forEach((section) => {
        observer.observe(section);
      });

      // Handle Astro view transitions if they are enabled later
      document.addEventListener("astro:after-swap", () => {
        document.querySelectorAll("section").forEach((section) => {
          observer.observe(section);
        });
      });
    </script>
  </body>
</html>
